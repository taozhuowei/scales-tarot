{
  "name": "scales-tarot",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "node scripts/build/index.js --prod --target h5,mp,server",
    "build:dev": "node scripts/build/index.js --dev --target h5,mp,server",
    "test": "npm run test -w test",
    "quality": "node scripts/quality_gate.js full",
    "ship": "node scripts/ship.js"
  },
  "simple-git-hooks": {
    "pre-commit": "node scripts/quality_gate.js staged",
    "commit-msg": "npx commitlint --edit $1",
    "pre-push": "node scripts/quality_gate.js full"
  },
  "workspaces": [
    "app",
    "server",
    "test"
  ],
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
