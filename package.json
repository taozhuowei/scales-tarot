    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
