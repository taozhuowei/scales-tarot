{
  "name": "scales-tarot-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:h5": "uni",
    "build:h5": "uni build",
    "dev:mp-weixin": "node ../node_modules/@dcloudio/vite-plugin-uni/bin/uni.js -p mp-weixin",
    "build:mp-weixin": "node ../node_modules/@dcloudio/vite-plugin-uni/bin/uni.js build -p mp-weixin",
    "dev:server": "tsx ../server/src/server.ts",
    "start": "concurrently -n server,h5 --prefix-colors cyan,yellow \"npm run dev:server\" \"npm run dev:h5\"",
    "test:unit": "vitest run",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-plus": "3.0.0-4080420251103001",
    "@dcloudio/uni-components": "3.0.0-4080420251103001",
    "@dcloudio/uni-h5": "3.0.0-4080420251103001",
    "gsap": "^3.14.2",
    "pinia": "^3.0.4",
    "vue": "3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080420251103001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-weixin": "^3.0.0-4080420251103001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080420251103001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@vue/runtime-core": "3.4.21",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.1.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^4.9.4",
    "vite": "5.2.8",
    "vitest": "^4.1.2",
    "vue-tsc": "^1.0.24"
  }
}
