# Server runtime environment
# Copy to .env and fill in. Production-only values live in the deploy host's
# /etc/scales-tarot.env (systemd EnvironmentFile=), NOT in this repo.

# fork: "development" or "production"
NODE_ENV=development

# Host/port the Node process binds to.
# - dev   default: 0.0.0.0:3000  (LAN-reachable for MP devtools)
# - prod  default: 127.0.0.1:3000 (behind nginx reverse proxy)
HOST=127.0.0.1
PORT=3000

# CORS allow-list for /api/*. Comma-separated origins.
# - Empty  in prod  → same-origin only (strict, recommended behind nginx).
# - "*"    in any  → permissive (dev only).
# Example: CORS_ORIGIN=https://tarot.example.com,https://www.tarot.example.com
CORS_ORIGIN=

# pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
