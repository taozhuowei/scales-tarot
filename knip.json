{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.js"]
    },
    "app": {
      "entry": [
        "src/main.ts",
        "src/App.vue",
        "src/pages/main/index.vue",
        "src/pages/fallback/index.vue"
      ],
      "project": [
        "src/**/*.{ts,vue}",
        "!src/**/*.d.ts"
      ]
    },
    "server": {
      "project": ["src/**/*.ts"]
    },
    "test": {
      "entry": ["**/*.test.ts", "**/*.spec.ts"],
      "project": ["**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "@dcloudio/uni-app-plus",
    "@dcloudio/uni-components",
    "@dcloudio/uni-h5",
    "@dcloudio/uni-mp-weixin",
    "@dcloudio/uni-automator",
    "@dcloudio/uni-cli-shared",
    "@dcloudio/uni-stacktracey",
    "@vue/runtime-core",
    "jscpd"
  ],
  "ignoreExportsUsedInFile": false,
  "vite": true,
  "rules": {
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "warn",
    "enumMembers": "warn",
    "classMembers": "warn"
  }
}
